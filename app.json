{
  "expo": {
    "name": "Disha",
    "slug": "disha",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "disha",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#C41C1C"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.disha.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#C41C1C"
      },
      "package": "com.disha.app",
      "versionCode": 1,
      "minSdkVersion": 23,
      "targetSdkVersion": 34,
      "softwareKeyboardLayoutMode": "pan",
      "permissions": [
        "NOTIFICATIONS",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#C41C1C"
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4a161e8a-3cbf-45a1-bfbb-d538f100192a"
      }
    },
    "owner": "gyanendu1197"
  }
}
